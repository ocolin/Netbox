{
    "name": "ocolin/netbox",
    "description": "PHP REST client for Netbox",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "homepage": "https://github.com/ocolin/netbox",
    "keywords": [
        "netbox",
        "netboxlabs",
        "api",
        "rest",
        "client",
        "network",
        "ipam",
        "dcim",
        "infrastructure"
    ],
    "type": "library",
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "ocolin/easyenv": "^3.0"
    },
    "license": "MIT",
    "autoload": {
    "psr-4": {
        "Ocolin\\Netbox\\": "src/"
    }
    },
    "autoload-dev": {
        "psr-4": {
            "Ocolin\\Netbox\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
        "name": "Colin Miller",
        "email": "ocolin@cruzio.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "guzzlehttp/guzzle": "^7.10",
        "ocolin/global-type": "^2.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit --no-coverage --display-deprecations --display-notices",
        "test-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-html coverage"
    }
}
